{
  "name": "Quiz Prototype",

  // Pulls a secure, pre-configured Debian/Ubuntu-based Python image
  "image": "mcr.microsoft.com/devcontainers/dotnet:8.0",

  // Automatically installs required packages into the container layer upon creation
  "postCreateCommand": "",

  "customizations": {
    "vscode": {
      // Configures the container's internal editor settings
      "settings": {
      },
      // Pre-installs key extensions so the workspace is immediately smart
      "extensions": [
        "ms-dotnettools.csdevkit",        // C#
      ]                                                                         }
  },

  // Ensures you aren't running commands blindly as root
  "remoteUser": "vscode"
}
